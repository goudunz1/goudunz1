" [indent and padding] {{{

" shortcut for tab shift
nnoremap <tab> >>
xnoremap <tab> >
nnoremap <s-tab> <<
xnoremap <s-tab> <

" hold <space> to add more space
func! s:addspace()
    exec "normal! i "
    redraw
    let ch = nr2char(getchar())
    while ch == ' '
        exec "normal! i "
        redraw
        let ch = nr2char(getchar())
    endwhile
endfunc

" press <leader>, then hold <space> to shift
nnoremap <leader><space> :call<space><sid>addspace()<cr>

" show hidden characters
nnoremap <leader>l :let &l:list=!&l:list<cr>
xnoremap <leader>l :let &l:list=!&l:list<cr>

" }}}

" [better command line] {{{

" tcsh-style command line (bash compatible)
cnoremap <c-a> <home>
cnoremap <c-b> <left>
cnoremap <c-f> <right>

" special command line characters
let g:cmdpairs={'(':')','[':']','{':'}','"':'"',"'":"'",'<':'>','`':'`',}

func! s:cmdautopair(ch, type)
    if a:type==#"pars"
        if has_key(g:cmdpairs, a:ch)
            return a:ch.g:cmdpairs[a:ch]."\<left>"
        elseif a:ch==getcmdline()[getcmdpos()-1]
            return "\<right>"
        endif
    elseif a:type==#"quotes"
        if has_key(g:cmdpairs, a:ch)
            return a:ch.a:ch."\<left>"
        elseif a:ch==getcmdline()[getcmdpos()-1]
            return "\<right>"
        endif
    elseif a:type==#"bs"&&a:ch==#"\<bs>"
        let pair=getcmdline()[getcmdpos()-1]
        let pair_l=getcmdline()[getcmdpos()-2]
        if has_key(g:cmdpairs, pair_l)&&(g:cmdpairs[pair_l]==pair)
            return "\<right>\<bs>\<bs>"
        endif
    endif
    return a:ch
endfunc

" auto complete command line key characters
cnoremap <expr> ( <sid>cmdautopair('(', 'pars')
cnoremap <expr> ) <sid>cmdautopair(')', 'pars')
cnoremap <expr> [ <sid>cmdautopair('[', 'pars')
cnoremap <expr> ] <sid>cmdautopair(']', 'pars')
cnoremap <expr> { <sid>cmdautopair('{', 'pars')
cnoremap <expr> } <sid>cmdautopair('}', 'pars')
cnoremap <expr> < <sid>cmdautopair('<', 'pars')
cnoremap <expr> > <sid>cmdautopair('>', 'pars')
cnoremap <expr> " <sid>cmdautopair('"', "quotes")
cnoremap <expr> ' <sid>cmdautopair("'", "quotes")
cnoremap <expr> ` <sid>cmdautopair("`", "quotes")
cnoremap <expr> <bs> <sid>cmdautopair("\<bs>", 'bs')

" }}}

augroup BufferEvents
    " [buffer events] {{{
    " define actions upon buffer entering and leaving
    autocmd!

    " remember the last position when re-opening a buffer
    autocmd BufReadPost * if line("'\"") > 1 && line("'\"") <= line("$") | exec "normal! g'\"" | endif

    " set cursor line if and only if window on focus
    autocmd BufEnter,WinEnter * setlocal cursorline
    autocmd BufLeave,WinLeave * setlocal nocursorline

    " }}}
augroup end

