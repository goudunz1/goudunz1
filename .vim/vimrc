xnoremap <leader><leader>t :tabe<cr>:vert term ++curwin ++close<cr>

" open up a terminal in a new tab under directory of current file (changes the
" register @s)
nnoremap <leader><leader>T :let @s=expand('%:p:h')<cr>:tabe<cr>:call term_start("bash",{"cwd":"<c-r>=@s<cr>","curwin":1,"term_finish":"close"})<cr>
