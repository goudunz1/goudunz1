" tabular {{{

nnoremap <leader>/" :Tabularize<space>/"\ze[^"]*$/l1c1l0
xnoremap <leader>/" :Tabularize<space>/"\ze[^"]*$/l1c1l0

nnoremap <leader>/# :Tabularize<space>/"\ze[^#]*$/l1c1l0
xnoremap <leader>/# :Tabularize<space>/"\ze[^#]*$/l1c1l0

nnoremap <leader>/ :Tabularize /
xnoremap <leader>/ :Tabularize /

" align <bar> in insert mode
func! s:align()
  let p = '^\s*|\s.*\s|\s*$'
  if exists(':Tabularize') && getline('.') =~# '^\s*|' && (getline(line('.')-1) =~# p || getline(line('.')+1) =~# p)
    let column = strlen(substitute(getline('.')[0:col('.')],'[^|]','','g'))
    let position = strlen(matchstr(getline('.')[0:col('.')],'.*|\s*\zs.*'))
    Tabularize/|/l1
    normal! 0
    call search(repeat('[^|]*|',column).'\s\{-\}'.repeat('.',position),'ce',line('.'))
  endif
endfunc

inoremap <bar> <bar><esc>:call <sid>align()<cr>a

