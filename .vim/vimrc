" [buffer manipulation] {{{

" reload/redraw buffer
nnoremap <leader>r :e<cr>
xnoremap <leader>r :e<cr>
nnoremap <leader>R :redraw!<cr>
xnoremap <leader>R :redraw!<cr>

func! s:changebuf(towards) abort
    if &bt!=''||&ft=='netrw'
        echoerr "functional buffer cannot be changed"|return
    endif
    if a:towards=='n'|bnext|else|bprevious|endif
	while &bt!=''||&ft=='netrw'
        if a:towards=='n'|bnext|else|bprevious|endif
    endwhile
endfunc

" select previous buffer
nnoremap <c-p> :call<space><sid>changebuf('p')<cr>
xnoremap <c-p> :call<space><sid>changebuf('p')<cr>
nnoremap <leader>j :call<space><sid>changebuf('p')<cr>
xnoremap <leader>j :call<space><sid>changebuf('p')<cr>

" select next buffer
nnoremap <c-n> :call<space><sid>changebuf('n')<cr>
xnoremap <c-n> :call<space><sid>changebuf('n')<cr>
nnoremap <leader>j :call<space><sid>changebuf('n')<cr>
xnoremap <leader>j :call<space><sid>changebuf('n')<cr>

func! s:closebuf()
    if bufname()==''||len(getbufinfo({'buflisted':1}))==0|quit|return|endif
    if &bt==''|bdelete
    elseif &bt=='quickfix'|cclose
    elseif &bt=='loclist'|lclose
    else|close
    endif
endfunc

" leave current buffer
nnoremap <leader>q :call<space><sid>closebuf()<cr>
xnoremap <leader>q :call<space><sid>closebuf()<cr>

" load file in new buffer
nnoremap <leader>e :edit<space><c-r>=getcwd()<cr>/
xnoremap <leader>e :edit<space><c-r>=getcwd()<cr>/
nnoremap <leader>E :edit<space>/
xnoremap <leader>E :edit<space>/
