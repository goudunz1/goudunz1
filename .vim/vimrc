" vista.vim {{{

if exists(":Vista")
    " enable vista icons
    let g:vista#renderer#enable_icon = 1
    
    " default vista backend
    let g:vista_default_executive = 'ctags'
    
    " shortcut to inspect symbols
    nnoremap <leader>y :Vista!!<space>coc
    
    " close buffer if vista is the only buffer remaining
    augroup Vista
    	autocmd!
    	autocmd BufEnter * if (&ft=='vista'||&ft=='vista_markdown')&&winnr('$')==1|bd|endif
    augroup END
endif

" }}}

" NERDTree {{{

if exists(":NERDTreeToggle")
    " NERDTree sidebar width
    let g:NERDTreeWinSize=28
    
    " show all hidden files and folders
    let g:NERDTreeShowHidden=1
    
    " shortcut to open sidebar
    nnoremap <leader>n :NERDTreeToggle<cr>
    
    " delete buffer if NERDTree is the only buffer remaining
    augroup NERDTree
        autocmd!
        autocmd BufEnter * if winnr('$')==1&&exists('b:NERDTree')&&b:NERDTree.isTabTree()|bd|endif
    augroup END
endif

" }}}

" auto-pairs {{{

if exists("g:AutoPairs")
    " disable some pre-defined maps
    let g:AutoPairsMapCh=0
    let g:AutoPairsMapBS=0
    let g:AutoPairsMapCR=0
    
    " file specific pairs
    augroup AutoPairs
        autocmd!
        autocmd FileType php let b:AutoPairs=AutoPairsDefine({'<?':'?>','<?php':'?>'})
        autocmd FileType rust let b:AutoPairs=AutoPairsDefine({'\w\zs<':'>'})
        autocmd FileType html let b:AutoPairs=AutoPairsDefine({'<':'>','<!--':'-->'})
    augroup END
endif

" }}}

" tabular {{{

if exists(':Tabularize')

    " tabular patterns goes here
    AddTabularPattern! last_double_quote /"\ze[^"]*$/l1c1l0
    AddTabularPattern! last_quote /'\ze[^']*$/l1c1l0

    " align <bar> in insert mode
    func! s:align()
      let p = '^\s*|\s.*\s|\s*$'
      if exists(':Tabularize') && getline('.') =~# '^\s*|' && (getline(line('.')-1) =~# p || getline(line('.')+1) =~# p)
        let column = strlen(substitute(getline('.')[0:col('.')],'[^|]','','g'))
        let position = strlen(matchstr(getline('.')[0:col('.')],'.*|\s*\zs.*'))
        Tabularize/|/l1
        normal! 0
        call search(repeat('[^|]*|',column).'\s\{-\}'.repeat('.',position),'ce',line('.'))
      endif
    endfunc

    " tabular shortcuts goes here
    nnoremap <leader>/ :Tabularize /
    xnoremap <leader>/ :Tabularize /
    inoremap <bar> <bar><esc>:call <sid>align()<cr>a
endif

" }}}

