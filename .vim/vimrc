" buffer manipulation {{{

" reload/redraw buffer
nnoremap <leader>r :e<cr>
xnoremap <leader>r :e<cr>
nnoremap <leader>R :redraw!<cr>
xnoremap <leader>R :redraw!<cr>

func! s:change_buf(towards) abort
    if &bt != '' || &ft == 'netrw'
        echoerr "buffer". &bt. " cannot be changed"
        return
    endif
    if a:towards == 'n' | bn | else | bp | endif
	while &bt != '' || &ft == 'netrw'
        if a:towards == 'n' | bn | else | bp | endif
    endwhile
endfunc

" select previous buffer
nnoremap <c-p> :call<space><sid>change_buf('p')<cr>
xnoremap <c-p> :call<space><sid>change_buf('p')<cr>
nnoremap <leader>j :call<space><sid>change_buf('p')<cr>
xnoremap <leader>j :call<space><sid>change_buf('p')<cr>

" select next buffer
nnoremap <c-n> :call<space><sid>change_buf('n')<cr>
xnoremap <c-n> :call<space><sid>change_buf('n')<cr>
nnoremap <leader>k :call<space><sid>change_buf('n')<cr>
xnoremap <leader>k :call<space><sid>change_buf('n')<cr>

func! s:close_buf() abort
    if bufname() == '' || len(getbufinfo({'buflisted': 1})) == 0
        quit | return
    endif
    if &bt == '' | bdelete
    elseif &bt == 'quickfix' | cclose
    elseif &bt == 'loclist' | lclose
    else | close
    endif
endfunc

" leave current buffer
nnoremap <leader>q :call<space><sid>close_buf()<cr>
xnoremap <leader>q :call<space><sid>close_buf()<cr>

" save current buffer
nnoremap <leader>w :w<cr>
xnoremap <leader>w :w<cr>

" load file in new buffer
nnoremap <leader>e :edit<space><c-r>=getcwd()<cr>/
xnoremap <leader>e :edit<space><c-r>=getcwd()<cr>/
nnoremap <leader>E :edit<space>/
xnoremap <leader>E :edit<space>/

